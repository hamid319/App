# =========================
# iOS / Mac Safety Net (Crucial for Teammate)
# =========================

# CocoaPods (The iOS equivalent of pub-cache)
# We do not want to commit the actual libraries, just the lockfile.
ios/Pods/
ios/.symlinks/

# Flutter wrappers for iOS
# These are generated binaries. Never commit them.
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Generated.xcconfig
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*

# Xcode temporary build files
**/ios/**/xcshareddata/
**/ios/**/xcuserdata/
ios/*.mode1v3
ios/*.mode2v3
ios/*.moved-aside
ios/*.pbxuser
ios/*.perspectivev3